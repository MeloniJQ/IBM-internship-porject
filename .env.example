# Copy this file to .env and fill in your own values. Never commit the real .env file.

# Endpoint the app posts prompts to. This is OpenRouter's chat-completions endpoint,
# which is used here to reach Google's Gemini/Gemma models without a direct Google API key.
GEMINI_API_URL=https://openrouter.ai/api/v1/chat/completions

# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_API_KEY=your_openrouter_api_key_here

# Model slug to use (see https://openrouter.ai/models for the full list).
# Default below is free and requires no OpenRouter credits.
# For a real Gemini model (e.g. google/gemini-2.5-flash), you must add
# credits to your OpenRouter account first, or you'll get a 402 error.
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# Optional: protects the server-to-server /api/gemini_key endpoint.
# Leave blank to allow unauthenticated local testing of that endpoint.
GEMINI_SERVER_KEY=
